# --- server ---
PORT=8080

# --- redaction policy (defaults; overridable per-tenant or per-request) ---
# closed = a detection/redaction error BLOCKS the request (never forwards raw PII).
# open   = on a redaction error, forward the ORIGINAL body (NOT recommended; dev only).
FAIL_MODE=closed
# reversible | strip | off  — the default mode when no policy/header overrides it.
#   reversible: de-identify upstream, restore real values in the reply (incl. streaming).
#   strip:      irreversible placeholders ([EMAIL]); nothing restored. Hardened mode.
#   off:        passthrough verbatim (audited as a bypass).
DEFAULT_MODE=reversible
# Which entity sets are active by default. Comma list of: pii,phi,pci,secrets
ACTIVE_SETS=pii,phi,pci,secrets
# Stable pseudonyms: placeholder = <TYPE_HMAC(secret,value)> so the same value maps to
# the same token across requests (the model can correlate; the value is never stored).
# false => per-request counters (<EMAIL_1>). Requires TENANT_SECRET when true.
CONSISTENT_PSEUDONYMS=false
TENANT_SECRET=                # HMAC key for consistent pseudonyms (set a strong random value)

# --- audit ---
# Append-only, hash-chained JSONL of COUNTS/TYPES only — never raw values.
AUDIT_LOG=./audit.jsonl

# --- admin API ---
ADMIN_TOKEN=                 # required header x-admin-token for /admin/*; empty = open (dev only)
TENANT_FROM_AUTH=true        # when no X-Tenant, derive the tenant from the API key

# --- upstream bases (override for Azure / regional endpoints / data-residency) ---
OPENAI_BASE=https://api.openai.com
ANTHROPIC_BASE=https://api.anthropic.com
